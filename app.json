{
  "expo": {
    "name": "MirasHesaplayici",
    "slug": "MirasHesaplayici",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mirashesaplayici",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "edgeToEdgeEnabled": true,
    "predictiveBackGestureEnabled": false,
    "package": "com.erlivion.MirasHesaplayici",
    "extra": {
      "eas": {
        "projectId": "d67f6b1d-7b17-454b-bcde-831924705d02"
      }
    },
    "android": {
      "package": "com.erlivion.MirasHesaplayici"
    }
  },
  "web": {
    "output": "static",
    "favicon": "./assets/images/favicon.png"
  },
  "plugins": [
    "expo-router",
    [
      "expo-splash-screen",
      {
        "image": "./assets/images/splash-icon.png",
        "imageWidth": 200,
        "resizeMode": "contain",
        "backgroundColor": "#ffffff",
        "dark": {
          "backgroundColor": "#000000"
        }
      }
    ],
    [
      "react-native-google-mobile-ads",
      {
        "androidAppId": "ca-app-pub-2172632283744022~9031598277",
        "iosAppId": "ca-app-pub-2172632283744022~9031598277"
      }
    ]
  ],
  "experiments": {
    "typedRoutes": true,
    "reactCompiler": true
  },
  "extra": {
    "router": {},
    "eas": {
      "projectId": "d67f6b1d-7b17-454b-bcde-831924705d02"
    }
  }
}
